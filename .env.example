# RAF Connect environment template
# Copy to .env for local development. Do not commit real secrets.

EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_API_BASE_URL=https://api.example.raf-connect.local
EXPO_PUBLIC_SUPPORT_EMAIL=support@example.com
EXPO_PUBLIC_SUPPORT_PHONE=0800-000-000
EXPO_PUBLIC_ENABLE_MOCKS=true
